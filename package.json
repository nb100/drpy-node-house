{
  "name": "decentralized-file-storage",
  "version": "1.0.7",
  "description": "A decentralized file storage system using Bun, Fastify, and Helia (IPFS).",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "bun scripts/build-front.js && bun src/app.js",
    "dev": "bun scripts/build-front.js && bun --watch src/app.js",
    "build:front": "bun scripts/build-front.js",
    "pm2": "pm2 start src/app.js --name drpysh --interpreter bun",
    "pm2:start": "pm2 start src/app.js --name drpysh --interpreter bun",
    "pm2:stop": "pm2 stop drpysh",
    "pm2:restart": "pm2 restart drpysh",
    "pm2:delete": "pm2 delete drpysh",
    "pm2:logs": "pm2 logs drpysh",
    "reset-password": "bun scripts/manage_roles.js reset-password",
    "settings": "bun scripts/manage_settings.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "bun",
    "fastify",
    "ipfs",
    "helia",
    "decentralized",
    "storage"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@helia/unixfs": "^7.0.4",
    "@libp2p/tcp": "^11.0.10",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "blockstore-fs": "^3.0.2",
    "datastore-fs": "^11.0.2",
    "dompurify": "^3.3.2",
    "fastify": "^5.7.4",
    "helia": "^6.0.20",
    "libp2p": "^3.1.3",
    "marked": "^17.0.4",
    "mime-types": "^3.0.2",
    "multiformats": "^13.4.2",
    "sharp": "^0.34.5",
    "vue": "^3.5.29"
  }
}
